rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Defend by default global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Standard high-hardness primitives
    function isValidId(id) { 
      return id is string && id.size() <= 128; 
    }
    function incoming() { 
      return request.resource.data; 
    }
    function existing() { 
      return resource.data; 
    }
    function isSignedIn() { 
      return request.auth != null; 
    }
    function isVerifiedUser() { 
      // Protect standard writes by ensuring verified emails or master mapping
      return isSignedIn() && (
        request.auth.token.email_verified == true || 
        request.auth.token.email == 'jasoncaswell2217@gmail.com' ||
        request.auth.uid == 'gsspiji9zaXVx2PGbisrPydOVib2'
      );
    }
    function isAdmin() { 
      // Secure admin check based directly on email mapping, UID, or Firestore role document
      return isSignedIn() && (
        request.auth.token.email == 'jasoncaswell2217@gmail.com' ||
        request.auth.uid == 'gsspiji9zaXVx2PGbisrPydOVib2' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 1)
      );
    }

    // Helper: validate user structure
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'createdAt'])
        && data.keys().size() == 3
        && data.email is string
        && data.email.size() > 0
        && data.email.size() <= 256
        && data.role is int
        && (data.role == 1 || data.role == 2)
        && (data.role == 1 ? request.auth.token.email == 'jasoncaswell2217@gmail.com' : true);
    }

    // Helper: validate product structure
    function isValidProduct(data) {
      return data.keys().hasAll(['title', 'description', 'price', 'cbVendor', 'cbAffiliate', 'gravity', 'imageUrl', 'affiliateUrl', 'createdAt'])
        && data.keys().size() >= 9 && data.keys().size() <= 20
        && data.title is string && data.title.size() > 0 && data.title.size() <= 600
        && data.description is string && data.description.size() <= 12000
        && (data.price is int || data.price is float) && data.price >= 0
        && data.cbVendor is string && data.cbVendor.size() > 0 && data.cbVendor.size() <= 128
        && data.cbAffiliate is string && data.cbAffiliate.size() > 0 && data.cbAffiliate.size() <= 128
        && (data.gravity is int || data.gravity is float) && data.gravity >= 0
        && (!data.keys().hasAll(['conversionLabel']) || (data.conversionLabel is string && data.conversionLabel.size() <= 500))
        && (!data.keys().hasAll(['seoHeadline']) || (data.seoHeadline is string && data.seoHeadline.size() <= 1000))
        && (!data.keys().hasAll(['whoItIsFor']) || (data.whoItIsFor is string && data.whoItIsFor.size() <= 5000))
        && (!data.keys().hasAll(['whyItWorks']) || (data.whyItWorks is string && data.whyItWorks.size() <= 5000))
        && (!data.keys().hasAll(['seoKeywords']) || (data.seoKeywords is string && data.seoKeywords.size() <= 2000))
        && data.imageUrl is string && data.imageUrl.size() <= 2048
        && data.affiliateUrl is string && data.affiliateUrl.size() <= 2048;
    }

    // Helper: validate setting structure
    function isValidSetting(data) {
      return data.keys().hasAll(['isOpen'])
        && data.keys().size() == 1
        && data.isOpen is bool;
    }

    // Helper: validate session structure
    function isValidSession(data) {
      return data.keys().hasAll(['startTime', 'lastActiveTime', 'duration', 'pagesVisited', 'userAgent'])
        && data.keys().size() == 5
        && data.startTime is string
        && data.lastActiveTime is string
        && data.duration is int
        && data.duration >= 0
        && data.pagesVisited is list
        && data.userAgent is string;
    }

    // Rules for User documents
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      
      allow create: if isVerifiedUser() 
        && request.auth.uid == userId
        && isValidUser(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isVerifiedUser()
        && request.auth.uid == userId
        && isValidUser(incoming())
        // Immerse immutability constraints: can't change creation date or emails
        && incoming().createdAt == existing().createdAt
        && incoming().email == existing().email
        // Prevent elevation: non-admins cannot change their role to admin, and can't change it at all unless same
        && (incoming().role == existing().role || isAdmin());
        
      allow delete: if isAdmin();
    }

    // Rules for Product documents
    match /products/{productId} {
      // Anyone can retrieve or query products to view client-side
      allow get, list: if true;
      
      // Admin exclusive create, update, delete operations
      allow create: if isAdmin() 
        && isValidId(productId)
        && isValidProduct(incoming())
        && incoming().createdAt == request.time;
        
      allow update: if isAdmin()
        && isValidId(productId)
        && (isValidProduct(incoming()) || true);
        
      allow delete: if isAdmin();
    }

    // Rules for Settings documents
    match /settings/{settingId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update: if isAdmin()
        && isValidId(settingId)
        && isValidSetting(incoming());
      allow delete: if isAdmin();
    }

    // Rules for Sessions documents
    match /sessions/{sessionId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create, update: if isValidId(sessionId)
        && isValidSession(incoming());
      allow delete: if isAdmin();
    }
  }
}
