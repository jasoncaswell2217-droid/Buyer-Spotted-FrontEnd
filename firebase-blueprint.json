{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing roles and metadata.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "The email address of the registered user."
        },
        "role": {
          "type": "integer",
          "description": "1 for Administrator, 2 for Guest.",
          "enum": [1, 2]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when user was registered."
        }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Affiliate ClickBank products added by the Administrator.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title or name of the product."
        },
        "description": {
          "type": "string",
          "description": "Brief product description."
        },
        "price": {
          "type": "number",
          "description": "Est. retail price or potential commission in USD."
        },
        "cbVendor": {
          "type": "string",
          "description": "ClickBank Vendor Nickname/ID."
        },
        "cbAffiliate": {
          "type": "string",
          "description": "ClickBank Affiliate account nickname."
        },
        "gravity": {
          "type": "number",
          "description": "ClickBank Gravity rating score."
        },
        "conversionLabel": {
          "type": "string",
          "description": "Conversion label detailing expected payout, e.g., '$139.00 avg payout'."
        },
        "imageUrl": {
          "type": "string",
          "description": "Web URL to the product image."
        },
        "affiliateUrl": {
          "type": "string",
          "description": "The custom/generated ClickBank Hoplink redirect URL."
        },
        "seoHeadline": {
          "type": "string",
          "description": "SEO Headline for dynamic pre-sell landing page."
        },
        "whoItIsFor": {
          "type": "string",
          "description": "Target demographics or audience details."
        },
        "whyItWorks": {
          "type": "string",
          "description": "Why the conversion mechanism works."
        },
        "seoKeywords": {
          "type": "string",
          "description": "Comma-separated keywords for SEO context."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp."
        }
      },
      "required": ["title", "description", "price", "cbVendor", "cbAffiliate", "gravity", "imageUrl", "affiliateUrl", "createdAt"]
    },
    "Setting": {
      "title": "Setting",
      "description": "Global settings for the website.",
      "type": "object",
      "properties": {
        "isOpen": {
          "type": "boolean",
          "description": "True if the website is open to regular users, false if under construction."
        }
      },
      "required": ["isOpen"]
    },
    "Session": {
      "title": "Session",
      "description": "Visitor session details.",
      "type": "object",
      "properties": {
        "startTime": {
          "type": "string",
          "description": "ISO timestamp when session began."
        },
        "lastActiveTime": {
          "type": "string",
          "description": "ISO timestamp of most recent interaction."
        },
        "duration": {
          "type": "integer",
          "description": "Elapsed seconds active on site."
        },
        "pagesVisited": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Page traversal history tracker."
        },
        "userAgent": {
          "type": "string",
          "description": "Resolved platform metadata."
        }
      },
      "required": ["startTime", "lastActiveTime", "duration", "pagesVisited", "userAgent"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "Rich affiliate marketing blog posts created by the administrator.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the blog post."
        },
        "slug": {
          "type": "string",
          "description": "Custom or auto-generated SEO-friendly URL slug."
        },
        "content": {
          "type": "string",
          "description": "Markdown, HTML, or Rich text content of the article."
        },
        "category": {
          "type": "string",
          "description": "Category for the post e.g. Wellness, DIY."
        },
        "status": {
          "type": "string",
          "enum": ["draft", "published"],
          "description": "Draft or fully published state."
        },
        "visibility": {
          "type": "string",
          "enum": ["public", "admins", "members"],
          "description": "Restrictive access configuration."
        },
        "seoKeywords": {
          "type": "string",
          "description": "Target keywords for SEO optimisation."
        },
        "readingTime": {
          "type": "integer",
          "description": "Estimated time to read in minutes."
        },
        "ctaText": {
          "type": "string",
          "description": "Call to action button label."
        },
        "ctaLink": {
          "type": "string",
          "description": "Affiliate Hoplink associated with the CTA button."
        },
        "imageUrl": {
          "type": "string",
          "description": "Article featured banner URL."
        },
        "authorName": {
          "type": "string",
          "description": "Author displaying handle."
        },
        "viewCount": {
          "type": "integer",
          "description": "Dynamic tracking code view counter."
        },
        "featuredProductId": {
          "type": "string",
          "description": "Optionally tied to an underlying curated product ID."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Post custom creation stamp."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Post last updated action stamp."
        }
      },
      "required": ["title", "slug", "content", "category", "status", "visibility", "createdAt", "updatedAt"]
    },
    "BlogCategory": {
      "title": "BlogCategory",
      "description": "Custom category definitions specifically for blog posts.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The custom name of the blog category."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp of the blog category."
        }
      },
      "required": ["name", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile store."
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Curated ClickBank products."
    },
    "settings/{settingId}": {
      "schema": "Setting",
      "description": "Global config store."
    },
    "sessions/{sessionId}": {
      "schema": "Session",
      "description": "Visitor analytics session tracking."
    },
    "blogPosts/{postId}": {
      "schema": "BlogPost",
      "description": "Rich blog reviews and marketing content repository."
    },
    "blogCategories/{categoryId}": {
      "schema": "BlogCategory",
      "description": "Blog categories configured by the Administrator."
    }
  }
}
